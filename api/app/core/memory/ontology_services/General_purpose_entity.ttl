@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix :      <http://redbear.ai/ontology/extract_task#> .

#
# Extract Triplet Ontology (Entity Ontology)
#
# 来源：<project_root>/ontology.md  —  Entity Ontology 13 类
# 目的：为 extract_triplet 任务提供实体类型白名单，作为通用本体注入 prompt。
# 注意：本文件只承载实体本体（owl:Class）。Predicate 本体通过 prompt 模板和
#       app/core/memory/utils/data/ontology.py 维护，未在此文件内定义。
#

# -------- 虚拟根节点，便于 merger 的父类层次提示 --------
:实体 a owl:Class ;
    rdfs:label "实体"@zh , "Entity"@en ;
    rdfs:comment "extract_triplet 任务本体的虚拟根类型，用于为 13 个实体类型提供统一的父类层次。"@zh .

# -------- 1. 生命体 --------
:生命体 a owl:Class ;
    rdfs:label "生命体"@zh , "LivingBeing"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "可稳定指向、可被当作具体个体区分和归并的生命体个体。正例：用户、张三、王教授、小林、用户的小狗、我的猫；反例：老师、导师、学生、他们、一只狗、狗这种动物、一个朋友。强调“这个生命体是谁或是哪一个”，不强调社会身份或泛化类别；用户自指统一归为 `用户`；有稳定所有格指向?new_block = 
# -------- 2. 组织 --------
:组织 a owl:Class ;
    rdfs:label "组织"@zh , "Organization"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "公司、机构、学校、实验室、团队、社群等组织性主体。正例：腾讯、清华大学、机器人公司、实验室；反例：人事部、教研组、办公室。组织内部单元当前仍并入 `组织`。"@zh .

# -------- 3. 群体 --------
:群体 a owl:Class ;
    rdfs:label "群体"@zh , "Group"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "边界相对稳定、可被当作整体引用的一组人。正例：我的朋友、同事们、实验室成员；反例：他们、一些人、一个朋友。边界不稳或 unresolved 的表达不要归入。"@zh .

# -------- 4. 角色职业 --------
:角色职业 a owl:Class ;
    rdfs:label "角色职业"@zh , "RoleOccupation"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "人物承担的社会角色、功能身份或职业身份。正例：导师、老师、学生、医生、程序员；反例：张三、王教授、我的朋友。强调“这个人是什么身份”，不强调“这个人是谁”；若文本落到具体个人，优先用 `生命体`。"@zh .

# -------- 5. 地点设施 --------
:地点设施 a owl:Class ;
    rdfs:label "地点设施"@zh , "PlaceFacility"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "具有地理意义或功能性空间意义的位置与场所。正例：北京、巴黎、图书馆、办公室、教室；反例：这里、那里、朝这边、明天去的地方。未稳定解析的位置指代表达不要抽取。"@zh .

# -------- 6. 物品设备 --------
:物品设备 a owl:Class ;
    rdfs:label "物品设备"@zh , "PhysicalItem"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "可被持有、使用、携带的具体物体、设备、工具或交通工具。正例：手机、电脑、相机、自行车、机器人查票员、智能助手；反例：微信、GitHub、会员服务。交通工具并入此类；数字服务不归入；极简版中，非人行动主体（如机器人）也暂并入本类。"@zh .

# -------- 7. 软件平台 --------
:软件平台 a owl:Class ;
    rdfs:label "软件平台"@zh , "SoftwarePlatform"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "软件、应用、网站、在线平台或数字服务系统。正例：微信、GitHub、ChatGPT、飞书；反例：iPhone、手机号、邮箱。若语境强调登录、识别或联系信息本身，改用 `识别联系信息`。"@zh .

# -------- 8. 识别联系信息 --------
:识别联系信息 a owl:Class ;
    rdfs:label "识别联系信息"@zh , "IdentifierContactInfo"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "账号、用户名、编号、邮箱、手机号等与识别、联系或登录相关的信息对象。正例：GitHub账号、微信号、学号、工号、用户名、手机号、邮箱；反例：微信、张三、简历。极简版中将原先的 `账号`、`标识符`、`联系方式` 合并为一类。"@zh .

# -------- 9. 文档媒体 --------
:文档媒体 a owl:Class ;
    rdfs:label "文档媒体"@zh , "DocumentMedia"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "文章、报告、表格、图片、音频、视频等内容载体。正例：简历、论文、照片、录音；反例：微积分、微信、学号。若只是内容主题，不归入本类。"@zh .

# -------- 10. 知识能力 --------
:知识能力 a owl:Class ;
    rdfs:label "知识能力"@zh , "KnowledgeSkill"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "可学习、掌握、使用或讨论的知识主题、技能、学科或语言。正例：微积分、机器学习、写作、Python、中文；反例：紧张、成功、意义。不包含情绪、心理状态、抽象结果或价值判断。"@zh .

# -------- 11. 偏好习惯 --------
:偏好习惯 a owl:Class ;
    rdfs:label "偏好习惯"@zh , "PreferenceHabit"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "用户稳定的偏好、重复习惯或长期行为倾向。正例：喜欢安静环境、晨跑、偏好黑咖啡、每天记笔记；反例：紧张、开心、成功、通过雅思。只保留稳定偏好与重复习惯，不包含情绪状态，也不包含具体目标结果。"@zh .

# -------- 12. 具体目标 --------
:具体目标 a owl:Class ;
    rdfs:label "具体目标"@zh , "ConcreteGoal"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "用户具体、明确、可验证、可长期追踪的目标结果或目标性安排。正例：通过雅思、完成毕业论文、每周读两篇论文；反例：成功、更有意义、迎接新的挑战、紧张。不保留宽泛愿望、抽象追求或价值判断。"@zh .

# -------- 13. 称呼别名 --------
:称呼别名 a owl:Class ;
    rdfs:label "称呼别名"@zh , "AliasTerm"@en ;
    rdfs:subClassOf :实体 ;
    rdfs:comment "用于指代或称呼实体的名字。正例：山哥、老张、X1；反例：导师、程序员、好人。只用于名字性表达，不用于角色、职业、评价词。"@zh .
